#!/command/with-contenv bash
# shellcheck shell=bash

# Only start if HTTP_BRIDGE_PORT is explicitly set
if [ -z "${HTTP_BRIDGE_PORT}" ]; then
    echo "HTTP_BRIDGE_PORT not set — HTTP bridge disabled. Sleeping forever."
    exec sleep infinity
fi

exec \
    s6-notifyoncheck -d -n 300 -w 1000 -c "nc -z localhost ${HTTP_BRIDGE_PORT}" \
        s6-setuidgid abc /lsiopy/bin/python3 /usr/local/bin/wyoming-http-bridge
