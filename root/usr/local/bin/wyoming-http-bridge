#!/lsiopy/bin/python3
"""
HTTP → Wyoming bridge for faster-whisper.
Uses the official wyoming library for wire protocol.

Endpoints:
    POST /stt                          — binary WAV audio → {"text": "..."}
    POST /v1/audio/transcriptions      — OpenAI-compatible (multipart/form-data)
    GET  /health                       — {"status": "ok"}
"""

import asyncio
import io
import json
import os
import sys
import tempfile
import wave

from aiohttp import web, MultipartReader

# Wyoming protocol types
from wyoming.asr import Transcribe, Transcript
from wyoming.audio import AudioChunk, AudioStop
from wyoming.event import async_read_event, async_write_event


def _wav_to_pcm(wav_bytes: bytes) -> bytes:
    """Strip WAV header to get raw PCM data."""
    if wav_bytes[:4] != b"RIFF":
        return wav_bytes  # Already raw PCM

    # Find "data" chunk in WAV
    for i in range(len(wav_bytes) - 4):
        if wav_bytes[i : i + 4] == b"data":
            chunk_size = int.from_bytes(wav_bytes[i + 4 : i + 8], "little")
            return wav_bytes[i + 8 : i + 8 + chunk_size]

    # Fallback: skip standard 44-byte header
    return wav_bytes[44:]


def _ensure_wav(audio_bytes: bytes) -> bytes:
    """Convert raw PCM to WAV if it's not already WAV."""
    if audio_bytes[:4] == b"RIFF":
        return audio_bytes  # Already WAV

    # Assume raw PCM 16kHz 16-bit mono, wrap in WAV
    buf = io.BytesIO()
    with wave.open(buf, "wb") as w:
        w.setnchannels(1)
        w.setsampwidth(2)
        w.setframerate(16000)
        w.writeframes(audio_bytes)
    return buf.getvalue()


_STT_TIMEOUT = int(os.environ.get("WHISPER_TIMEOUT", "60"))


async def wyoming_transcribe(
    host: str, port: int, wav_bytes: bytes, timeout: float = None
) -> str:
    """Send WAV audio to Wyoming STT server, return transcription text."""
    effective_timeout = timeout if timeout is not None else _STT_TIMEOUT
    reader, writer = await asyncio.wait_for(
        asyncio.open_connection(host, port), timeout=5.0
    )
    try:
        pcm_data = _wav_to_pcm(wav_bytes)

        # Send audio in 4KB chunks
        chunk_size = 4096
        for offset in range(0, len(pcm_data), chunk_size):
            chunk = pcm_data[offset : offset + chunk_size]
            await async_write_event(
                AudioChunk(
                    audio=chunk,
                    rate=16000,
                    width=2,
                    channels=1,
                ).event(),
                writer,
            )

        # AudioStop triggers transcription
        await async_write_event(AudioStop().event(), writer)
        await writer.drain()

        # Collect Transcript events
        transcript_parts = []
        while True:
            event = await asyncio.wait_for(
                async_read_event(reader), timeout=effective_timeout
            )
            if event is None:
                break
            if Transcript.is_type(event.type):
                transcript = Transcript.from_event(event)
                if transcript.text:
                    transcript_parts.append(transcript.text)
                else:
                    break

        return " ".join(transcript_parts)

    except asyncio.TimeoutError:
        return "[error: timeout waiting for transcription]"
    except Exception:
        raise
    finally:
        try:
            writer.close()
            await writer.wait_closed()
        except (BrokenPipeError, ConnectionResetError):
            pass


# ── HTTP handlers ────────────────────────────────────────────────────
STT_HOST = os.environ.get("WHISPER_HOST", "127.0.0.1")
STT_PORT = int(os.environ.get("WHISPER_PORT", "10300"))
BRIDGE_PORT = int(os.environ.get("HTTP_BRIDGE_PORT", "0"))
_PREFIX = os.environ.get("URL_PREFIX", "/whisper")

routes = web.RouteTableDef()


@routes.get("/health")
@routes.get(f"{_PREFIX}/health")
async def health(_request):
    return web.json_response({"status": "ok"})


@routes.post("/stt")
@routes.post(f"{_PREFIX}/stt")
async def handle_stt(request):
    audio_data = await request.read()
    if not audio_data:
        return web.json_response({"error": "no audio data"}, status=400)

    text = await wyoming_transcribe(STT_HOST, STT_PORT, audio_data)
    return web.json_response({"text": text})


@routes.post("/v1/audio/transcriptions")
@routes.post(f"{_PREFIX}/v1/audio/transcriptions")
async def handle_openai_stt(request):
    """
    OpenAI-compatible STT endpoint.
    
    Accepts multipart/form-data with:
      - file: the audio file (required)
      - model: model name (optional, ignored - we use the configured model)
      - language: language hint (optional, e.g. "en", "fr")
      - response_format: "json" (default) or "text"
    
    Returns {"text": "..."} or plain text depending on response_format.
    """
    content_type = request.content_type or ""
    audio_data = None
    language = None
    response_format = "json"

    if "multipart/form-data" in content_type:
        reader = MultipartReader.from_response(request)
        while True:
            part = await reader.next()
            if part is None:
                break
            field_name = part.name if part.name else ""
            if field_name == "file":
                audio_data = await part.read()
            elif field_name == "language":
                language = (await part.text()).strip()
            elif field_name == "response_format":
                response_format = (await part.text()).strip()
            elif field_name == "model":
                # Ignored — we transcribe with whatever the server has
                pass
    else:
        # Fallback: read raw body (for backward compat)
        audio_data = await request.read()

    if not audio_data:
        return web.json_response(
            {"error": "no audio data provided"}, status=400
        )

    # Ensure it's WAV (Wyoming expects 16kHz 16-bit mono WAV)
    wav_data = _ensure_wav(audio_data)
    text = await wyoming_transcribe(STT_HOST, STT_PORT, wav_data)

    if response_format == "text":
        return web.Response(text=text, content_type="text/plain")
    return web.json_response({"text": text})


def main():
    if not BRIDGE_PORT:
        print("HTTP_BRIDGE_PORT not set — exiting", file=sys.stderr)
        sys.exit(0)

    app = web.Application()
    app.add_routes(routes)
    print(f"HTTP bridge listening on 0.0.0.0:{BRIDGE_PORT}", file=sys.stderr)
    web.run_app(app, host="0.0.0.0", port=BRIDGE_PORT, print=lambda *a: None)


if __name__ == "__main__":
    main()